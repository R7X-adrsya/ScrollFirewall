<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/enable_accessibility_desc"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginTop="32dp"/>

    <Button
        android:id="@+id/btn_enable_service"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/enable_accessibility"
        android:layout_marginTop="16dp"/>

    <Switch
        android:id="@+id/switch_test_mode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/test_mode_toggle"
        android:layout_marginTop="32dp"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/tv_current_usage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/current_usage"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="48dp"/>

</LinearLayout>
